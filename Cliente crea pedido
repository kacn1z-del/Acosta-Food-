import { doc, setDoc } from "firebase/firestore";
import { db } from "../../services/firebaseConfig";

async function createOrder(clientId, restaurantId, location) {
  await setDoc(doc(db, "orders", "order123"), {
    clientId,
    restaurantId,
    status: "pending",
    location,
    createdAt: Date.now()
  });
}
