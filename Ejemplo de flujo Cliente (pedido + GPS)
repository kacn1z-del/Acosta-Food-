import React, { useEffect, useState } from 'react';
import { View, Text, Button } from 'react-native';
import MapView, { Marker } from 'react-native-maps';
import { doc, setDoc } from "firebase/firestore";
import { db } from "../../firebaseConfig";

export default function TrackingScreen() {
  const [location, setLocation] = useState({ lat: 9.9, lng: -84.1 });

  async function createOrder() {
    await setDoc(doc(db, "orders", "order123"), {
      clientId: "user123",
      restaurantId: "rest456",
      status: "pending",
      location
    });
  }

  return (
    <View style={{ flex: 1 }}>
      <MapView style={{ flex: 1 }} initialRegion={{
        latitude: location.lat,
        longitude: location.lng,
        latitudeDelta: 0.05,
        longitudeDelta: 0.05
      }}>
        <Marker coordinate={{ latitude: location.lat, longitude: location.lng }} title="Cliente" />
      </MapView>
      <Button title="Crear Pedido" onPress={createOrder} />
    </View>
  );
}
